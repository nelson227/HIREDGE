# ─────────────────────────────────────────────────────────
# HIREDGE API - Variables d'Environnement Production (Railway)
# ─────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────
NODE_ENV=production
PORT=3000
API_URL=https://your-app.up.railway.app

# ─── Database (fourni par Railway) ───────────
DATABASE_URL=postgresql://...

# ─── Redis (fourni par Railway) ──────────────
REDIS_URL=redis://...

# ─── JWT (OBLIGATOIRE - générer des secrets uniques) ─────
# Générer avec: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_ANOTHER_SECRET

# ─── CORS ────────────────────────────────────
CORS_ORIGIN=https://hiredge.vercel.app

# ─── OpenAI ──────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Anthropic (Claude) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Pinecone (optionnel) ───────────────────
PINECONE_API_KEY=
PINECONE_INDEX=hiredge-jobs

# ─── S3 / Cloudflare R2 (optionnel) ─────────
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=hiredge-files

# ─── Email - Resend (optionnel) ─────────────
RESEND_API_KEY=
FROM_EMAIL=noreply@hiredge.app
