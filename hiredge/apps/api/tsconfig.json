{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": true,
    "types": ["node", "vitest/globals"],
    "paths": {
      "@/*": ["./src/*"],
      "@hiredge/shared": ["../../packages/shared/src"],
      "@hiredge/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src", "prisma", "scripts"],
  "exclude": ["node_modules", "dist"]
}
