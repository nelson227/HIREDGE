# ──────────────────────────────────────────────
# HIREDGE — Variables d'Environnement
# Copier ce fichier en .env et remplir les valeurs
# ──────────────────────────────────────────────

# ─── Server ──────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ─── Database ────────────────────────────────
DATABASE_URL=postgresql://hiredge:hiredge_dev_2024@localhost:5432/hiredge
POSTGRES_PASSWORD=hiredge_dev_2024

# ─── Redis ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────
JWT_SECRET=replace-with-a-secure-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-with-another-secure-random-string-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── OpenAI ──────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=

# ─── Anthropic (Claude) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Pinecone (vector DB) ───────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX=hiredge-jobs

# ─── AWS S3 (fichiers) ──────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
AWS_S3_BUCKET=hiredge-uploads

# ─── Email (SMTP) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=HIREDGE <noreply@hiredge.app>

# ─── ElevenLabs (TTS) ───────────────────────
ELEVENLABS_API_KEY=

# ─── Sentry (error tracking) ────────────────
SENTRY_DSN=

# ─── App Config ─────────────────────────────
MAX_FREE_APPLICATIONS_PER_MONTH=3
PREMIUM_PRICE_MONTHLY=12.99
SQUAD_MIN_MEMBERS=5
SQUAD_MAX_MEMBERS=8
