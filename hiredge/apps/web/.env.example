# ─────────────────────────────────────────────────────────
# HIREDGE WEB - Variables d'Environnement (Vercel)
# ─────────────────────────────────────────────────────────

# API Backend URL (Railway)
NEXT_PUBLIC_API_URL=https://your-app.up.railway.app

# WebSocket URL (même que l'API mais avec wss://)
NEXT_PUBLIC_WS_URL=wss://your-app.up.railway.app

# App Name
NEXT_PUBLIC_APP_NAME=HIREDGE
