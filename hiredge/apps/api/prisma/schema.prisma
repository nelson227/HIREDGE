generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// UTILISATEURS
// ============================================================

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  passwordHash     String
  role             String           @default("CANDIDATE")
  subscriptionTier String           @default("FREE")
  locale           String           @default("fr")
  isEmailVerified  Boolean          @default(false)
  lastActiveAt     DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  candidateProfile   CandidateProfile?
  scout              Scout?
  notifications      Notification[]
  chatMessages       EdgeChatMessage[]
  edgeConversations  EdgeConversation[]
  sessions           Session[]
  applications       Application[]
  squadMembers       SquadMember[]
  squadMessages      SquadMessage[]
  simulations        InterviewSimulation[]
  scoutConversations ScoutConversation[] @relation("CandidateConversations")

  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ============================================================
// PROFILS CANDIDATS
// ============================================================

model CandidateProfile {
  id               String           @id @default(uuid())
  userId           String           @unique
  firstName        String           @default("")
  lastName         String           @default("")
  title            String           @default("")
  bio              String?
  avatarUrl        String?
  phone            String?
  city             String?
  country          String?
  linkedinUrl      String?
  portfolioUrl     String?
  availableFrom    DateTime?
  remotePreference String           @default("HYBRID")
  salaryMin        Int?
  salaryMax        Int?
  salaryCurrency   String           @default("EUR")
  yearsExperience  Float            @default(0)
  preparationScore Int              @default(0)
  completionScore  Int              @default(0)
  onboardingDone   Boolean          @default(false)
  cvUrl            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills      Skill[]
  experiences Experience[]
  educations  Education[]

  @@map("candidate_profiles")
}

model Skill {
  id                String     @id @default(uuid())
  profileId         String
  name              String
  level             String     @default("INTERMEDIATE")
  yearsOfExperience Float?
  createdAt         DateTime   @default(now())

  profile CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("skills")
}

model Experience {
  id          String    @id @default(uuid())
  profileId   String
  company     String
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  current     Boolean   @default(false)
  location    String?
  createdAt   DateTime  @default(now())

  profile CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("experiences")
}

model Education {
  id          String    @id @default(uuid())
  profileId   String
  institution String
  degree      String
  field       String?
  startDate   DateTime?
  endDate     DateTime?
  current     Boolean   @default(false)
  createdAt   DateTime  @default(now())

  profile CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("education")
}

// ============================================================
// OFFRES D'EMPLOI
// ============================================================

model Company {
  id                         String   @id @default(uuid())
  name                       String
  website                    String?
  logo                       String?
  industry                   String?
  sizeRange                  String?
  location                   String?
  glassdoorRating            Float?
  cultureSummary             String?
  avgRecruitmentDurationDays Int?
  avgResponseRate            Float?
  avgSalaryJson              String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  jobs               Job[]
  scouts             Scout[]
  collectiveInsights CollectiveInsight[]

  @@map("companies")
}

model Job {
  id              String       @id @default(uuid())
  title           String
  companyId       String
  description     String       @default("")
  requiredSkills  String       @default("[]")
  niceToHave      String       @default("[]")
  benefits        String       @default("[]")
  salaryMin       Int?
  salaryMax       Int?
  salaryCurrency  String       @default("EUR")
  location        String?
  locationCity    String?
  locationCountry String?
  remote          Boolean      @default(false)
  contractType    String       @default("CDI")
  status          String       @default("ACTIVE")
  externalId      String?
  source          String?
  sourceUrl       String?
  isScam          Boolean      @default(false)
  experienceMin   Int?
  experienceMax   Int?
  postedAt        DateTime     @default(now())
  expiresAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  company      Company       @relation(fields: [companyId], references: [id])
  applications Application[]
  simulations  InterviewSimulation[]

  @@index([companyId])
  @@index([status])
  @@index([contractType])
  @@index([locationCountry, locationCity])
  @@index([createdAt])
  @@map("jobs")
}

// ============================================================
// CANDIDATURES
// ============================================================

model Application {
  id                 String            @id @default(uuid())
  userId             String
  jobId              String
  status             String            @default("DRAFT")
  matchScore         Int               @default(0)
  coverLetterContent String?
  cvVersion          String?
  interviewDate      DateTime?
  followUpDate       DateTime?
  rejectionReason    String?
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id])

  @@unique([userId, jobId])
  @@index([userId, status])
  @@index([jobId])
  @@map("applications")
}

// ============================================================
// ESCOUADES
// ============================================================

model Squad {
  id          String      @id @default(uuid())
  name        String
  description String?
  industry    String?
  maxMembers  Int         @default(8)
  status      String      @default("FORMING")
  createdAt   DateTime    @default(now())
  dissolvedAt DateTime?
  updatedAt   DateTime    @updatedAt

  members  SquadMember[]
  messages SquadMessage[]

  @@index([status])
  @@map("squads")
}

model SquadMember {
  id       String          @id @default(uuid())
  squadId  String
  userId   String
  role     String          @default("MEMBER")
  isActive Boolean         @default(true)
  joinedAt DateTime        @default(now())
  leftAt   DateTime?

  squad Squad @relation(fields: [squadId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([squadId, userId])
  @@index([squadId, isActive])
  @@map("squad_members")
}

model SquadMessage {
  id        String           @id @default(uuid())
  squadId   String
  userId    String
  content   String
  audioUrl  String?
  type      String           @default("TEXT")
  createdAt DateTime         @default(now())

  squad Squad @relation(fields: [squadId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([squadId, createdAt])
  @@map("squad_messages")
}

// ============================================================
// Ã‰CLAIREURS
// ============================================================

model Scout {
  id             String      @id @default(uuid())
  userId         String      @unique
  companyId      String
  department     String?
  position       String?
  yearsAtCompany Int?
  isAnonymous    Boolean     @default(true)
  anonymousAlias String      @default("")
  credits        Int         @default(0)
  creditBalance  Int         @default(0)
  trustScore     Int         @default(50)
  ratingAvg      Float       @default(0)
  ratingCount    Int         @default(0)
  isVerified     Boolean     @default(false)
  hiredDate      DateTime?
  status         String      @default("PENDING")
  questionnaireJson String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  company       Company           @relation(fields: [companyId], references: [id])
  conversations ScoutConversation[]

  @@index([companyId, status])
  @@map("scouts")
}

model ScoutConversation {
  id          String   @id @default(uuid())
  scoutId     String
  candidateId String
  jobId       String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())

  scout     Scout        @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  candidate User         @relation("CandidateConversations", fields: [candidateId], references: [id], onDelete: Cascade)
  messages  ScoutMessage[]

  @@index([scoutId])
  @@index([candidateId])
  @@map("scout_conversations")
}

model ScoutMessage {
  id             String     @id @default(uuid())
  conversationId String
  senderId       String
  senderType     String
  content        String
  isAnonymized   Boolean    @default(false)
  createdAt      DateTime   @default(now())

  conversation ScoutConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("scout_messages")
}

// ============================================================
// SIMULATIONS D'ENTRETIEN
// ============================================================

model InterviewSimulation {
  id              String    @id @default(uuid())
  userId          String
  jobId           String?
  type            String    @default("HR")
  companyName     String?
  jobTitle        String?
  durationSeconds Int       @default(0)
  score           Int       @default(0)
  transcriptJson  String?
  analysisJson    String?
  config          String?
  audioUrl        String?
  status          String    @default("IN_PROGRESS")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job?  @relation(fields: [jobId], references: [id])

  @@index([userId, createdAt])
  @@map("interview_simulations")
}

// ============================================================
// INTELLIGENCE COLLECTIVE
// ============================================================

model CollectiveInsight {
  id              String   @id @default(uuid())
  companyId       String
  insightType     String
  contentJson     String
  sourceCount     Int      @default(1)
  confidenceScore Float    @default(0.5)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, insightType])
  @@map("collective_insights")
}

// ============================================================
// AGENT EDGE â€” Conversations
// ============================================================

model EdgeConversation {
  id        String   @id @default(uuid())
  userId    String
  title     String   @default("Nouvelle conversation")
  summary   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages EdgeChatMessage[]

  @@index([userId, updatedAt])
  @@index([userId, isActive])
  @@map("edge_conversations")
}

model EdgeChatMessage {
  id             String   @id @default(uuid())
  userId         String
  conversationId String?
  role           String
  content        String
  metadata       String?
  createdAt      DateTime @default(now())

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation EdgeConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([conversationId, createdAt])
  @@map("edge_chat_messages")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  actionUrl String?
  metadata  String?
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}


